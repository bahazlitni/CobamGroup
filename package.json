{
  "name": "cobam-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @cobam/cobam-group",
    "dev:main": "npm run dev --workspace @cobam/cobam-group",
    "dev:e-cobam": "npm run dev --workspace @cobam/e-cobam",
    "build": "npm run build --workspace @cobam/cobam-group",
    "build:main": "npm run build --workspace @cobam/cobam-group",
    "build:e-cobam": "npm run build --workspace @cobam/e-cobam",
    "build:all": "turbo run build",
    "start": "npm run start --workspace @cobam/cobam-group",
    "lint": "npm run lint --workspace @cobam/cobam-group",
    "lint:all": "turbo run lint",
    "typecheck": "npm run typecheck --workspace @cobam/cobam-group",
    "typecheck:all": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "rbac:reset": "npm run rbac:reset --workspace @cobam/cobam-group",
    "staff:seed": "npm run staff:seed --workspace @cobam/cobam-group",
    "test:unit": "npm run test:unit --workspace @cobam/cobam-group",
    "test:watch": "npm run test:watch --workspace @cobam/cobam-group"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@fontsource/sora": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@google/genai": "^1.50.1",
    "@next/third-parties": "^16.2.4",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tiptap/extension-color": "^3.20.5",
    "@tiptap/extension-image": "^3.20.2",
    "@tiptap/extension-link": "^3.20.2",
    "@tiptap/extension-placeholder": "^3.20.2",
    "@tiptap/extension-table": "^3.20.5",
    "@tiptap/extension-table-cell": "^3.20.5",
    "@tiptap/extension-table-header": "^3.20.5",
    "@tiptap/extension-table-row": "^3.20.5",
    "@tiptap/extension-text-style": "^3.20.5",
    "@tiptap/extension-underline": "^3.20.2",
    "@tiptap/pm": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.36.0",
    "jose": "^6.2.1",
    "lenis": "^1.3.21",
    "libphonenumber-js": "^1.12.40",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "react-phone-number-input": "^3.4.16",
    "shadcn": "^4.0.5",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/date-fns": "^2.5.3",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "turbo": "^2.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
