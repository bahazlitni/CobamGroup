generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MediaKind {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaVisibility {
  PRIVATE
  PUBLIC
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaLinkRole {
  COVER
  GALLERY
  THUMBNAIL
  BANNER
  SEO_COVER
  SWATCH
  INLINE
  TECHNICAL_SHEET_IMAGE
  LIFESTYLE
}

enum Portal {
  CUSTOMER
  STAFF
}

enum PowerType {
  ROOT
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  CLOSED
}

enum ProductKind {
  STANDARD
  VARIANT
  SINGLE
}

enum ProductLifecycle {
  DRAFT
  ACTIVE
  DISCONTINUED
}

enum ProductTypeAttributeInputType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  COLOR
  FINISH
}

enum OTPType {
  LOGIN
  RESET_PASSWORD
  VERIFY_EMAIL
}

enum ProductAvailability {
  IN_STOCK
  ON_ORDER
  OUT_OF_STOCK
}

enum ProductInventoryVisibility {
  AUTO // Show exact stock only when quantity is low or unavailable
  ALWAYS // Always show stock quantity/status
  NEVER // Never show exact stock, only generic availability
}

enum ProductPricingVisibility {
  AUTO // Show price only when product is commercially purchasable
  ALWAYS // Always show price if a price exists
  NEVER // Never show price publicly
}

enum ProductSubcategoryRole {
  ECOMMERCE
  VITRINE
  BOTH
}

enum ProductMediaRole {
  GALLERY
  TECHNICAL
  CERTIFICATE
}

enum StockUnit {
  PIECE

  // Weight
  TON
  KILOGRAM
  GRAM
  MILLIGRAM

  // Volume
  CUBIC_METER
  LITER
  CENTILITER
  MILLILITER

  // Length
  METER
  CENTIMETER
  MILLIMETER

  // Area
  SQUARE_METER
  SQUARE_CENTIMETER
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

enum CustomerAddressType {
  BILLING
  SHIPPING
  BOTH
}

enum ShoppingCartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum CheckoutSessionStatus {
  OPEN
  COMPLETED
  EXPIRED
  CANCELLED
}

enum CommerceOrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum CommercePaymentMethod {
  CARD
  BANK_TRANSFER
  CASH_ON_DELIVERY
  PAY_IN_STORE
}

enum CommercePaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum CommerceRefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum CommerceFulfillmentMethod {
  DELIVERY
  PICKUP
}

enum CommerceFulfillmentStatus {
  PENDING
  SCHEDULED
  PREPARING
  READY
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum CommercePromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

enum CommerceDiscountType {
  PERCENT
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum CommerceInvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum CommerceReturnRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  REFUNDED
  CANCELLED
}

enum CommerceReturnItemStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  REFUNDED
}

enum CommerceMessageVisibility {
  CUSTOMER
  STAFF_INTERNAL
}

enum CommerceStockReservationStatus {
  RESERVED
  RELEASED
  CONSUMED
  EXPIRED
}

model User {
  id                         String     @id @default(cuid())
  email                      String     @unique
  passwordHash               String     @map("password_hash")
  portal                     Portal     @default(STAFF)
  powerType                  PowerType  @default(USER) @map("power_type")
  status                     UserStatus @default(ACTIVE)
  bannedAt                   DateTime?  @map("banned_at")
  bannedReason               String?    @map("banned_reason") @db.Text
  closedAt                   DateTime?  @map("closed_at")
  lastLoginAt                DateTime?  @map("last_login_at")
  passwordChangedAt          DateTime?  @map("password_changed_at")
  twoStepVerificationEnabled Boolean    @default(true) @map("two_step_verification_enabled")
  createdAt                  DateTime   @default(now()) @map("created_at")
  updatedAt                  DateTime   @updatedAt @map("updated_at")

  refreshTokens            RefreshToken[]
  otpChallenges            OTPChallenge[]
  passwordResetTokens      PasswordResetToken[]
  uploadedMedia            Media[]              @relation("MediaUploadedByUser")
  articles                 Article[]            @relation("ArticleAuthor")
  articleAuthorLinks       ArticleAuthorLink[]
  createdArticleCategories ArticleCategory[]    @relation("ArticleCategoryCreatedByUser")
  updatedArticleCategories ArticleCategory[]    @relation("ArticleCategoryUpdatedByUser")
  profile                  StaffProfile?
  customerProfile          CustomerProfile?

  receivedRoleAssignments   UserRoleAssignment[]       @relation("RoleAssignmentTarget")
  grantedRoleAssignments    UserRoleAssignment[]       @relation("RoleAssignmentGrantedBy")
  revokedRoleAssignments    UserRoleAssignment[]       @relation("RoleAssignmentRevokedBy")
  commerceOrderStatusEvents CommerceOrderStatusEvent[] @relation("CommerceOrderStatusEventCreatedBy")
  commerceFulfillmentEvents CommerceFulfillmentEvent[] @relation("CommerceFulfillmentEventCreatedBy")
  commerceOrderMessages     CommerceOrderMessage[]     @relation("CommerceOrderMessageStaffUser")

  @@index([powerType])
  @@index([status])
  @@map("users")
}

model OTPChallenge {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  codeHash           String    @map("code_hash")
  challengeTokenHash String?   @map("challenge_token_hash")
  type               OTPType
  attempts           Int       @default(0)
  expiresAt          DateTime? @map("expires_at")
  consumedAt         DateTime? @map("consumed_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@index([challengeTokenHash])
  @@index([createdAt])
  @@map("otp_challenges")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model StaffProfile {
  id            BigInt    @id @default(autoincrement())
  userId        String    @unique @map("user_id")
  firstName     String?   @map("first_name") @db.VarChar(100)
  lastName      String?   @map("last_name") @db.VarChar(100)
  jobTitle      String?   @map("job_title") @db.VarChar(150)
  phone         String?   @db.VarChar(50)
  bio           String?
  birthDate     DateTime? @map("birth_date")
  avatarMediaId BigInt?   @map("avatar_media_id")

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarMedia Media? @relation("StaffProfileAvatarMedia", fields: [avatarMediaId], references: [id], onDelete: SetNull)

  @@index([avatarMediaId])
  @@map("profiles")
}

model AnnuairePerson {
  id        BigInt   @id @default(autoincrement())
  lastName  String   @default("") @map("last_name") @db.VarChar(150)
  firstName String   @default("") @map("first_name") @db.VarChar(150)
  jobTitle  String   @default("") @map("job_title") @db.VarChar(200)
  email     String   @default("") @db.VarChar(255)
  site      String   @default("") @db.VarChar(200)
  extension String   @default("") @db.VarChar(80)
  whatsapp  String   @default("") @db.VarChar(80)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([lastName, firstName])
  @@index([site])
  @@index([jobTitle])
  @@index([sortOrder])
  @@map("annuaire_people")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  key         String   @unique @db.VarChar(150) // e.g. "products.update.own"
  label       String   @db.VarChar(255)
  resource    String   @db.VarChar(100) // e.g. "products"
  action      String   @db.VarChar(100) // e.g. "update"
  scope       String?  @db.VarChar(50) // e.g. "own", "any", "below_role"
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roleLinks RolePermission[]

  @@index([resource, action])
  @@map("permissions")
}

model Role {
  id            BigInt   @id @default(autoincrement())
  key           String   @unique @db.VarChar(100)
  name          String   @db.VarChar(150)
  color         String   @db.VarChar(30)
  priorityIndex Int      @default(100) @map("priority_index")
  description   String?  @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  permissionLinks RolePermission[]
  userAssignments UserRoleAssignment[]

  @@index([priorityIndex])
  @@index([isActive])
  @@map("roles")
}

model RolePermission {
  roleId       BigInt  @map("role_id")
  permissionId BigInt  @map("permission_id")
  allowed      Boolean @default(true)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id              BigInt    @id @default(autoincrement())
  userId          String    @map("user_id")
  roleId          BigInt    @map("role_id")
  grantedByUserId String?   @map("granted_by_user_id")
  revokedByUserId String?   @map("revoked_by_user_id")
  grantedAt       DateTime  @default(now()) @map("granted_at")
  revokedAt       DateTime? @map("revoked_at")
  reason          String?   @db.Text

  user          User  @relation("RoleAssignmentTarget", fields: [userId], references: [id], onDelete: Cascade)
  role          Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedByUser User? @relation("RoleAssignmentGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  revokedByUser User? @relation("RoleAssignmentRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt])
  @@index([roleId, revokedAt])
  @@map("user_role_assignments")
}

model RefreshToken {
  id                 String    @id @default(cuid())
  tokenHash          String    @map("token_hash")
  userId             String    @map("user_id")
  expiresAt          DateTime  @map("expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  revokedAt          DateTime? @map("revoked_at")
  lastUsedAt         DateTime? @map("last_used_at")
  createdByIpAddress String?   @map("created_by_ip_address") @db.VarChar(100)
  createdByUserAgent String?   @map("created_by_user_agent") @db.Text
  replacedByTokenId  String?   @map("replaced_by_token_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model CustomerProfile {
  id                       BigInt       @id @default(autoincrement())
  userId                   String       @unique @map("user_id")
  type                     CustomerType @default(INDIVIDUAL)
  firstName                String?      @map("first_name") @db.VarChar(100)
  lastName                 String?      @map("last_name") @db.VarChar(100)
  companyName              String?      @map("company_name") @db.VarChar(255)
  taxIdentifier            String?      @map("tax_identifier") @db.VarChar(100)
  phone                    String?      @db.VarChar(50)
  emailMarketingOptIn      Boolean      @default(false) @map("email_marketing_opt_in")
  smsMarketingOptIn        Boolean      @default(false) @map("sms_marketing_opt_in")
  defaultBillingAddressId  BigInt?      @map("default_billing_address_id")
  defaultShippingAddressId BigInt?      @map("default_shipping_address_id")
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  user                   User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultBillingAddress  CustomerAddress?              @relation("CustomerDefaultBillingAddress", fields: [defaultBillingAddressId], references: [id], onDelete: SetNull)
  defaultShippingAddress CustomerAddress?              @relation("CustomerDefaultShippingAddress", fields: [defaultShippingAddressId], references: [id], onDelete: SetNull)
  addresses              CustomerAddress[]             @relation("CustomerAddresses")
  paymentMethods         CustomerPaymentMethod[]
  carts                  ShoppingCart[]
  checkoutSessions       CheckoutSession[]
  orders                 CommerceOrder[]
  promotionRedemptions   CommercePromotionRedemption[]
  couponScopes           CommerceCouponCustomer[]
  notifications          CustomerNotification[]
  wishlistItems          CommerceWishlistItem[]
  returnRequests         CommerceReturnRequest[]
  orderMessages          CommerceOrderMessage[]
  stockReservations      CommerceStockReservation[]

  @@index([type])
  @@index([defaultBillingAddressId])
  @@index([defaultShippingAddressId])
  @@map("customer_profiles")
}

model CustomerAddress {
  id                BigInt              @id @default(autoincrement())
  customerId        BigInt              @map("customer_id")
  type              CustomerAddressType @default(BOTH)
  label             String?             @db.VarChar(100)
  fullName          String              @map("full_name") @db.VarChar(255)
  phone             String?             @db.VarChar(50)
  addressLine1      String              @map("address_line_1") @db.VarChar(255)
  addressLine2      String?             @map("address_line_2") @db.VarChar(255)
  city              String              @db.VarChar(120)
  governorate       String?             @db.VarChar(120)
  postalCode        String?             @map("postal_code") @db.VarChar(30)
  countryCode       String              @default("TN") @map("country_code") @db.VarChar(2)
  isDefaultBilling  Boolean             @default(false) @map("is_default_billing")
  isDefaultShipping Boolean             @default(false) @map("is_default_shipping")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  customer           CustomerProfile         @relation("CustomerAddresses", fields: [customerId], references: [id], onDelete: Cascade)
  defaultBillingFor  CustomerProfile[]       @relation("CustomerDefaultBillingAddress")
  defaultShippingFor CustomerProfile[]       @relation("CustomerDefaultShippingAddress")
  paymentMethods     CustomerPaymentMethod[]

  @@index([customerId])
  @@index([type])
  @@map("customer_addresses")
}

model CustomerPaymentMethod {
  id                      BigInt                @id @default(autoincrement())
  customerId              BigInt                @map("customer_id")
  method                  CommercePaymentMethod @default(BANK_TRANSFER)
  label                   String?               @db.VarChar(120)
  provider                String?               @db.VarChar(80)
  providerPaymentMethodId String?               @map("provider_payment_method_id") @db.VarChar(191)
  holderName              String?               @map("holder_name") @db.VarChar(255)
  billingAddressId        BigInt?               @map("billing_address_id")
  isDefault               Boolean               @default(false) @map("is_default")
  isActive                Boolean               @default(true) @map("is_active")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")

  customer       CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  billingAddress CustomerAddress? @relation(fields: [billingAddressId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([billingAddressId])
  @@index([method])
  @@index([isActive])
  @@map("customer_payment_methods")
}

model CustomerNotification {
  id         BigInt    @id @default(autoincrement())
  customerId BigInt    @map("customer_id")
  orderId    BigInt?   @map("order_id")
  type       String    @db.VarChar(80)
  title      String    @db.VarChar(255)
  body       String    @db.Text
  href       String?   @db.VarChar(500)
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order    CommerceOrder?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([customerId, readAt, createdAt])
  @@index([orderId])
  @@map("customer_notifications")
}

model ShoppingCart {
  id         BigInt             @id @default(autoincrement())
  customerId BigInt?            @map("customer_id")
  guestToken String?            @unique @map("guest_token") @db.VarChar(191)
  status     ShoppingCartStatus @default(ACTIVE)
  currency   String             @default("TND") @db.VarChar(3)
  expiresAt  DateTime?          @map("expires_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  customer          CustomerProfile?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items             ShoppingCartItem[]
  checkoutSessions  CheckoutSession[]
  convertedOrder    CommerceOrder?             @relation("OrderSourceCart")
  stockReservations CommerceStockReservation[]

  @@index([customerId, status])
  @@index([status])
  @@index([expiresAt])
  @@map("shopping_carts")
}

model ShoppingCartItem {
  id            BigInt   @id @default(autoincrement())
  cartId        BigInt   @map("cart_id")
  productId     BigInt   @map("product_id")
  quantity      Decimal  @db.Decimal(12, 3)
  unitPriceTtc  Decimal? @map("unit_price_ttc") @db.Decimal(12, 3)
  vatRate       Decimal  @default(19.000) @map("vat_rate") @db.Decimal(5, 3)
  priceSnapshot Json?    @map("price_snapshot") @db.Json
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cart    ShoppingCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
  @@index([productId])
  @@map("shopping_cart_items")
}

model CheckoutSession {
  id                      BigInt                @id @default(autoincrement())
  cartId                  BigInt                @map("cart_id")
  customerId              BigInt?               @map("customer_id")
  status                  CheckoutSessionStatus @default(OPEN)
  currency                String                @default("TND") @db.VarChar(3)
  subtotalTtc             Decimal               @default(0) @map("subtotal_ttc") @db.Decimal(12, 3)
  discountTtc             Decimal               @default(0) @map("discount_ttc") @db.Decimal(12, 3)
  shippingTtc             Decimal               @default(0) @map("shipping_ttc") @db.Decimal(12, 3)
  taxTtc                  Decimal               @default(0) @map("tax_ttc") @db.Decimal(12, 3)
  totalTtc                Decimal               @default(0) @map("total_ttc") @db.Decimal(12, 3)
  shippingAddressSnapshot Json?                 @map("shipping_address_snapshot") @db.Json
  billingAddressSnapshot  Json?                 @map("billing_address_snapshot") @db.Json
  expiresAt               DateTime              @map("expires_at")
  completedAt             DateTime?             @map("completed_at")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")

  cart     ShoppingCart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  customer CustomerProfile?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  payments CommercePayment[]

  @@index([cartId])
  @@index([customerId])
  @@index([status])
  @@index([expiresAt])
  @@map("checkout_sessions")
}

model CommerceOrder {
  id                      BigInt                    @id @default(autoincrement())
  orderNumber             String                    @unique @map("order_number") @db.VarChar(50)
  customerId              BigInt?                   @map("customer_id")
  cartId                  BigInt?                   @unique @map("cart_id")
  guestEmail              String?                   @map("guest_email") @db.VarChar(255)
  guestPhone              String?                   @map("guest_phone") @db.VarChar(50)
  status                  CommerceOrderStatus       @default(PENDING)
  paymentStatus           CommercePaymentStatus     @default(PENDING) @map("payment_status")
  fulfillmentStatus       CommerceFulfillmentStatus @default(PENDING) @map("fulfillment_status")
  currency                String                    @default("TND") @db.VarChar(3)
  subtotalTtc             Decimal                   @default(0) @map("subtotal_ttc") @db.Decimal(12, 3)
  discountTtc             Decimal                   @default(0) @map("discount_ttc") @db.Decimal(12, 3)
  shippingTtc             Decimal                   @default(0) @map("shipping_ttc") @db.Decimal(12, 3)
  taxTtc                  Decimal                   @default(0) @map("tax_ttc") @db.Decimal(12, 3)
  totalTtc                Decimal                   @default(0) @map("total_ttc") @db.Decimal(12, 3)
  customerSnapshot        Json?                     @map("customer_snapshot") @db.Json
  billingAddressSnapshot  Json?                     @map("billing_address_snapshot") @db.Json
  shippingAddressSnapshot Json?                     @map("shipping_address_snapshot") @db.Json
  notes                   String?                   @db.Text
  cancellationReason      String?                   @map("cancellation_reason") @db.Text
  placedAt                DateTime                  @default(now()) @map("placed_at")
  confirmedAt             DateTime?                 @map("confirmed_at")
  cancelledAt             DateTime?                 @map("cancelled_at")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")

  customer             CustomerProfile?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cart                 ShoppingCart?                 @relation("OrderSourceCart", fields: [cartId], references: [id], onDelete: SetNull)
  items                CommerceOrderItem[]
  statusEvents         CommerceOrderStatusEvent[]
  payments             CommercePayment[]
  refunds              CommerceRefund[]
  fulfillments         CommerceFulfillment[]
  promotionRedemptions CommercePromotionRedemption[]
  notifications        CustomerNotification[]
  invoice              CommerceInvoice?
  returnRequests       CommerceReturnRequest[]
  messages             CommerceOrderMessage[]
  stockReservations    CommerceStockReservation[]

  @@index([customerId, placedAt])
  @@index([status])
  @@index([paymentStatus])
  @@index([fulfillmentStatus])
  @@index([placedAt])
  @@map("commerce_orders")
}

model CommerceOrderItem {
  id                 BigInt    @id @default(autoincrement())
  orderId            BigInt    @map("order_id")
  productId          BigInt?   @map("product_id")
  sku                String    @db.VarChar(100)
  name               String    @db.VarChar(255)
  slug               String?   @db.VarChar(255)
  imageUrl           String?   @map("image_url") @db.VarChar(500)
  brandName          String?   @map("brand_name") @db.VarChar(255)
  quantity           Decimal   @db.Decimal(12, 3)
  stockUnit          StockUnit @default(PIECE) @map("stock_unit")
  unitPriceTtc       Decimal?  @map("unit_price_ttc") @db.Decimal(12, 3)
  vatRate            Decimal   @default(19.000) @map("vat_rate") @db.Decimal(5, 3)
  discountTtc        Decimal   @default(0) @map("discount_ttc") @db.Decimal(12, 3)
  lineSubtotalTtc    Decimal   @default(0) @map("line_subtotal_ttc") @db.Decimal(12, 3)
  lineTotalTtc       Decimal   @default(0) @map("line_total_ttc") @db.Decimal(12, 3)
  attributesSnapshot Json?     @map("attributes_snapshot") @db.Json
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  order       CommerceOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  returnItems CommerceReturnItem[]

  @@index([orderId])
  @@index([productId])
  @@index([sku])
  @@map("commerce_order_items")
}

model CommerceOrderStatusEvent {
  id              BigInt               @id @default(autoincrement())
  orderId         BigInt               @map("order_id")
  fromStatus      CommerceOrderStatus? @map("from_status")
  toStatus        CommerceOrderStatus  @map("to_status")
  note            String?              @db.Text
