generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MediaKind {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaVisibility {
  PRIVATE
  PUBLIC
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaLinkRole {
  COVER
  GALLERY
  THUMBNAIL
  BANNER
  SEO_COVER
  SWATCH
  INLINE
  TECHNICAL_SHEET_IMAGE
  LIFESTYLE
}

enum Portal {
  CUSTOMER
  STAFF
}

enum PowerType {
  ROOT
  ADMIN
  STAFF
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  CLOSED
}

enum ProductKind {
  STANDARD
  VARIANT
  SINGLE
}

enum ProductLifecycle {
  DRAFT
  ACTIVE
}

enum ProductTypeAttributeInputType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  COLOR
  FINISH
}

enum OTPType {
  LOGIN
  RESET_PASSWORD
  VERIFY_EMAIL
}

enum ProductAvailability {
  IN_STOCK
  ON_ORDER
  OUT_OF_STOCK
  DISCONTINUED
}

enum ProductInventoryVisibility {
  AUTO // Show exact stock only when quantity is low or unavailable
  ALWAYS // Always show stock quantity/status
  NEVER // Never show exact stock, only generic availability
}

enum ProductPricingVisibility {
  AUTO // Show price only when product is commercially purchasable
  ALWAYS // Always show price if a price exists
  NEVER // Never show price publicly
}

enum ProductSubcategoryRole {
  ECOMMERCE
  VITRINE
  BOTH
}

enum ProductMediaRole {
  GALLERY
  TECHNICAL
  CERTIFICATE
}

enum StockUnit {
  PIECE

  // Weight
  TON
  KILOGRAM
  GRAM
  MILLIGRAM

  // Volume
  CUBIC_METER
  LITER
  CENTILITER
  MILLILITER

  // Length
  METER
  CENTIMETER
  MILLIMETER

  // Area
  SQUARE_METER
  SQUARE_CENTIMETER
}

model User {
  id                         String     @id @default(cuid())
  email                      String     @unique
  passwordHash               String     @map("password_hash")
  portal                     Portal     @default(STAFF)
  powerType                  PowerType  @default(STAFF) @map("power_type")
  status                     UserStatus @default(ACTIVE)
  bannedAt                   DateTime?  @map("banned_at")
  bannedReason               String?    @map("banned_reason") @db.Text
  closedAt                   DateTime?  @map("closed_at")
  lastLoginAt                DateTime?  @map("last_login_at")
  passwordChangedAt          DateTime?  @map("password_changed_at")
  twoStepVerificationEnabled Boolean    @default(true) @map("two_step_verification_enabled")
  createdAt                  DateTime   @default(now()) @map("created_at")
  updatedAt                  DateTime   @updatedAt @map("updated_at")

  refreshTokens            RefreshToken[]
  otpChallenges            OTPChallenge[]
  uploadedMedia            Media[]             @relation("MediaUploadedByUser")
  articles                 Article[]           @relation("ArticleAuthor")
  articleAuthorLinks       ArticleAuthorLink[]
  createdArticleCategories ArticleCategory[]   @relation("ArticleCategoryCreatedByUser")
  updatedArticleCategories ArticleCategory[]   @relation("ArticleCategoryUpdatedByUser")
  profile                  StaffProfile?

  receivedRoleAssignments UserRoleAssignment[] @relation("RoleAssignmentTarget")
  grantedRoleAssignments  UserRoleAssignment[] @relation("RoleAssignmentGrantedBy")
  revokedRoleAssignments  UserRoleAssignment[] @relation("RoleAssignmentRevokedBy")

  @@index([powerType])
  @@index([status])
  @@map("users")
}

model OTPChallenge {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  codeHash  String   @map("code_hash")
  type      OTPType
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([createdAt])
  @@map("otp_challenges")
}

model StaffProfile {
  id            BigInt    @id @default(autoincrement())
  userId        String    @unique @map("user_id")
  firstName     String?   @map("first_name") @db.VarChar(100)
  lastName      String?   @map("last_name") @db.VarChar(100)
  jobTitle      String?   @map("job_title") @db.VarChar(150)
  phone         String?   @db.VarChar(50)
  bio           String?
  birthDate     DateTime? @map("birth_date")
  avatarMediaId BigInt?   @map("avatar_media_id")

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarMedia Media? @relation("StaffProfileAvatarMedia", fields: [avatarMediaId], references: [id], onDelete: SetNull)

  @@index([avatarMediaId])
  @@map("profiles")
}

model AnnuairePerson {
  id        BigInt   @id @default(autoincrement())
  lastName  String   @default("") @map("last_name") @db.VarChar(150)
  firstName String   @default("") @map("first_name") @db.VarChar(150)
  jobTitle  String   @default("") @map("job_title") @db.VarChar(200)
  email     String   @default("") @db.VarChar(255)
  site      String   @default("") @db.VarChar(200)
  extension String   @default("") @db.VarChar(80)
  whatsapp  String   @default("") @db.VarChar(80)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([lastName, firstName])
  @@index([site])
  @@index([jobTitle])
  @@index([sortOrder])
  @@map("annuaire_people")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  key         String   @unique @db.VarChar(150) // e.g. "products.update.own"
  label       String   @db.VarChar(255)
  resource    String   @db.VarChar(100) // e.g. "products"
  action      String   @db.VarChar(100) // e.g. "update"
  scope       String?  @db.VarChar(50) // e.g. "own", "any", "below_role"
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roleLinks RolePermission[]

  @@index([resource, action])
  @@map("permissions")
}

model Role {
  id            BigInt   @id @default(autoincrement())
  key           String   @unique @db.VarChar(100)
  name          String   @db.VarChar(150)
  color         String   @db.VarChar(30)
  priorityIndex Int      @default(100) @map("priority_index")
  description   String?  @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  permissionLinks RolePermission[]
  userAssignments UserRoleAssignment[]

  @@index([priorityIndex])
  @@index([isActive])
  @@map("roles")
}

model RolePermission {
  roleId       BigInt  @map("role_id")
  permissionId BigInt  @map("permission_id")
  allowed      Boolean @default(true)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id              BigInt    @id @default(autoincrement())
  userId          String    @map("user_id")
  roleId          BigInt    @map("role_id")
  grantedByUserId String?   @map("granted_by_user_id")
  revokedByUserId String?   @map("revoked_by_user_id")
  grantedAt       DateTime  @default(now()) @map("granted_at")
  revokedAt       DateTime? @map("revoked_at")
  reason          String?   @db.Text

  user          User  @relation("RoleAssignmentTarget", fields: [userId], references: [id], onDelete: Cascade)
  role          Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedByUser User? @relation("RoleAssignmentGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  revokedByUser User? @relation("RoleAssignmentRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt])
  @@index([roleId, revokedAt])
  @@map("user_role_assignments")
}

model RefreshToken {
  id                 String    @id @default(cuid())
  tokenHash          String    @map("token_hash")
  userId             String    @map("user_id")
  expiresAt          DateTime  @map("expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  revokedAt          DateTime? @map("revoked_at")
  lastUsedAt         DateTime? @map("last_used_at")
  createdByIpAddress String?   @map("created_by_ip_address") @db.VarChar(100)
  createdByUserAgent String?   @map("created_by_user_agent") @db.Text
  replacedByTokenId  String?   @map("replaced_by_token_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ProductCategory {
  id             BigInt   @id @default(autoincrement())
  name           String   @db.VarChar(255)
  subtitle       String?  @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)
  themeColor     String?  @map("theme_color") @db.VarChar(255)
  description    String?  @db.Text
  descriptionSeo String?  @map("description_seo") @db.VarChar(160)
  imageMediaId   BigInt?  @map("image_media_id")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  imageMedia    Media?               @relation("ProductCategoryImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)
  subcategories ProductSubcategory[]

  @@index([imageMediaId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("product_types")
}

model ProductSubcategory {
  id             BigInt   @id @default(autoincrement())
  categoryId     BigInt   @map("category_id")
  name           String   @db.VarChar(255)
  subtitle       String?  @db.VarChar(255)
  slug           String   @db.VarChar(255)
  description    String?  @db.Text
  descriptionSeo String?  @map("description_seo") @db.VarChar(160)
  imageMediaId   BigInt?  @map("image_media_id")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category           ProductCategory                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  imageMedia         Media?                         @relation("ProductSubcategoryImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)
  productLinks       ProductSubcategoryLink[]
  productTypePresets ProductTypeSubcategoryPreset[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([imageMediaId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("product_subcategories")
}

model Product {
  id BigInt @id @default(autoincrement())

  brandId       BigInt? @map("brand_id")
  productTypeId BigInt? @map("product_type_id")

  kind        ProductKind @default(STANDARD)
  slug        String      @unique @db.VarChar(255)
  sku         String      @unique @db.VarChar(100)
  name        String      @db.VarChar(255)
  displayName String      @map("display_name") @db.VarChar(255)

  richTextDescription Json?
  shortDescription    String? @map("short_description") @db.VarChar(500)

  titleSeo       String? @map("title_seo") @db.VarChar(60)
  descriptionSeo String? @map("description_seo") @db.VarChar(160)
  tags           String  @default("") @db.Text

  guaranteeMonths Int? @default(0) @map("guarantee_months")

  visibleEcommerce Boolean @default(true) @map("visible_ecommerce")
  visibleVitrine   Boolean @default(true) @map("visible_vitrine")
  isFeatured       Boolean @default(false) @map("is_featured")
  isPromoted       Boolean @default(false) @map("is_promoted")
  isNew            Boolean @default(false) @map("is_new")

  stockAvailable      Decimal                    @default(0) @map("stock_available") @db.Decimal(12, 3)
  stockAlertThreshold Decimal                    @default(0) @map("stock_alert_threshold") @db.Decimal(12, 3)
  stockUnit           StockUnit                  @default(PIECE) @map("stock_unit")
  stockAvailability   ProductAvailability        @default(IN_STOCK) @map("stock_availability")
  stockVisibility     ProductInventoryVisibility @default(AUTO) @map("stock_visibility")

  basePriceTtcTnd    Decimal?                 @map("base_price_ttc_tnd") @db.Decimal(12, 3)
  currentPriceTtcTnd Decimal?                 @map("current_price_ttc_tnd") @db.Decimal(12, 3)
  vatRate            Decimal                  @default(19.000) @map("vat_rate") @db.Decimal(5, 3)
  priceVisibility    ProductPricingVisibility @default(AUTO) @map("price_visibility")

  createdById     String?  @map("created_by_id") @db.VarChar(191)
  lastUpdatedById String?  @map("last_updated_by_id") @db.VarChar(191)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  familyMembership   ProductFamilyMember?
  defaultForFamilies ProductFamily[]          @relation("ProductFamilyDefaultProduct")
  brand              Organization?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  productType        ProductType?             @relation(fields: [productTypeId], references: [id], onDelete: SetNull)
  subcategories      ProductSubcategoryLink[]
  media              ProductMedia[]
  attributes         ProductAttribute[]

  @@index([brandId])
  @@index([productTypeId])
  @@index([visibleEcommerce])
  @@index([visibleVitrine])
  @@index([isPromoted])
  @@index([isFeatured])
  @@map("products")
}

model Organization {
  id BigInt @id @default(autoincrement())

  slug        String  @unique @db.VarChar(255)
  name        String  @db.VarChar(255)
  description String? @db.Text

  logoMediaId BigInt? @map("logo_media_id")

  isProductBrand Boolean @default(false) @map("is_product_brand")
  isReference    Boolean @default(false) @map("is_reference")
  isPartner      Boolean @default(false) @map("is_partner")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logoMedia Media?    @relation("OrganizationLogoMedia", fields: [logoMediaId], references: [id], onDelete: SetNull)
  products  Product[]

  @@index([logoMediaId])
  @@map("organizations")
}

model ProductSubcategoryLink {
  productId     BigInt @map("product_id")
  subcategoryId BigInt @map("subcategory_id")

  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  subcategory ProductSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  @@id([productId, subcategoryId])
  @@index([subcategoryId])
  @@map("product_subcategory_links")
}

model ProductMedia {
  id BigInt @id @default(autoincrement())

  productId BigInt @map("product_id")
  mediaId   BigInt @map("media_id")

  role      ProductMediaRole @default(GALLERY)
  name      String?          @db.VarChar(255)
  altText   String?          @map("alt_text") @db.VarChar(255)
  sortOrder Int              @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([productId, mediaId])
  @@index([productId])
  @@index([mediaId])
  @@index([productId, role])
  @@index([productId, sortOrder])
  @@map("product_media")
}

model ProductFamily {
  id               BigInt   @id @default(autoincrement())
  slug             String   @unique @db.VarChar(255)
  name             String   @db.VarChar(255)
  subtitle         String?  @db.VarChar(255)
  description      String?  @db.Text
  descriptionSeo   String?  @map("description_seo") @db.VarChar(160)
  mainImageMediaId BigInt?  @map("main_image_media_id")
  defaultProductId BigInt?  @map("default_product_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  mainImage      Media?                @relation("ProductFamilyMainImageMedia", fields: [mainImageMediaId], references: [id], onDelete: SetNull)
  defaultProduct Product?              @relation("ProductFamilyDefaultProduct", fields: [defaultProductId], references: [id], onDelete: SetNull)
  members        ProductFamilyMember[]

  @@index([mainImageMediaId])
  @@index([defaultProductId])
  @@map("product_families")
}

model ProductFamilyMember {
  familyId  BigInt @map("family_id")
  productId BigInt @unique @map("product_id")
  sortOrder Int    @default(0) @map("sort_order")

  family  ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([familyId, productId])
  @@index([sortOrder])
  @@map("product_family_members")
}

model ProductTypeGroup {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productTypes ProductType[]

  @@index([sortOrder])
  @@map("product_type_groups")
}

model ProductType {
  id                    BigInt     @id @default(autoincrement())
  groupId               BigInt?    @map("group_id")
  name                  String     @db.VarChar(255)
  slug                  String     @unique @db.VarChar(255)
  description           String?    @db.Text
  sortOrder             Int        @default(0) @map("sort_order")
  hasColor              Boolean    @default(false) @map("has_color")
  hasFinish             Boolean    @default(false) @map("has_finish")
  presetTags            String     @default("") @map("preset_tags") @db.Text
  presetStockUnit       StockUnit? @map("preset_stock_unit")
  presetVatRate         Decimal?   @map("preset_vat_rate") @db.Decimal(5, 3)
  presetGuaranteeMonths Int?       @map("preset_guarantee_months")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  group              ProductTypeGroup?              @relation(fields: [groupId], references: [id], onDelete: SetNull)
  attributeGroups    ProductAttributeGroup[]
  attributes         ProductTypeAttribute[]
  subcategoryPresets ProductTypeSubcategoryPreset[]
  products           Product[]

  @@index([groupId])
  @@index([sortOrder])
  @@map("product_type_templates")
}

model ProductTypeSubcategoryPreset {
  productTypeId BigInt @map("product_type_id")
  subcategoryId BigInt @map("subcategory_id")

  productType ProductType        @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  subcategory ProductSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  @@id([productTypeId, subcategoryId])
  @@index([subcategoryId])
  @@map("product_type_subcategory_presets")
}

model ProductAttributeGroup {
  id            BigInt   @id @default(autoincrement())
  productTypeId BigInt?  @map("product_type_id")
  name          String   @db.VarChar(255)
  slug          String   @db.VarChar(255)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  productType       ProductType?           @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  attributeDefs     ProductTypeAttribute[]
  productAttributes ProductAttribute[]

  @@unique([productTypeId, slug])
  @@index([productTypeId])
  @@index([sortOrder])
  @@map("product_attribute_groups")
}

model ProductAttributeDefinition {
  id            BigInt                        @id @default(autoincrement())
  key           String                        @unique @db.VarChar(150)
  label         String                        @db.VarChar(255)
  unit          String?                       @db.VarChar(50)
  inputType     ProductTypeAttributeInputType @default(TEXT) @map("input_type")
  selectOptions String[]                      @default([]) @map("select_options")
  createdAt     DateTime                      @default(now()) @map("created_at")
  updatedAt     DateTime                      @updatedAt @map("updated_at")

  templateAttributes ProductTypeAttribute[]
  productAttributes  ProductAttribute[]

  @@index([label])
  @@map("product_attribute_definitions")
}

model ProductTypeAttribute {
  id                    BigInt   @id @default(autoincrement())
  productTypeId         BigInt   @map("product_type_id")
  attributeGroupId      BigInt?  @map("attribute_group_id")
  attributeDefinitionId BigInt   @map("attribute_definition_id")
  label                 String   @default("") @db.VarChar(255)
  isRequired            Boolean  @default(false) @map("is_required")
  isFilterable          Boolean  @default(false) @map("is_filterable")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  productType         ProductType                @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  attributeGroup      ProductAttributeGroup?     @relation(fields: [attributeGroupId], references: [id], onDelete: SetNull)
  attributeDefinition ProductAttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Restrict)

  @@unique([productTypeId, attributeDefinitionId])
  @@index([productTypeId])
  @@index([attributeGroupId])
  @@index([attributeDefinitionId])
  @@index([sortOrder])
  @@map("product_type_attributes")
}

model ProductAttribute {
  id               BigInt                        @id @default(autoincrement())
  productId        BigInt                        @map("product_id")
  attributeDefId   BigInt?                       @map("attribute_def_id")
  attributeGroupId BigInt?                       @map("attribute_group_id")
  name             String                        @db.VarChar(150)
  label            String                        @default("") @db.VarChar(255)
  value            String                        @db.VarChar(255)
  unit             String?                       @db.VarChar(50)
  inputType        ProductTypeAttributeInputType @default(TEXT) @map("input_type")
  isRequired       Boolean                       @default(false) @map("is_required")
  isFilterable     Boolean                       @default(false) @map("is_filterable")
  groupName        String?                       @map("group_name") @db.VarChar(255)
  groupSortOrder   Int                           @default(0) @map("group_sort_order")
  sortOrder        Int                           @default(0) @map("sort_order")

  product        Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeDef   ProductAttributeDefinition? @relation(fields: [attributeDefId], references: [id], onDelete: SetNull)
  attributeGroup ProductAttributeGroup?      @relation(fields: [attributeGroupId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([attributeDefId])
  @@index([attributeGroupId])
  @@index([groupSortOrder])
  @@index([sortOrder])
  @@map("product_attributes")
}

model ProductColor {
  id        BigInt   @id @default(autoincrement())
  key       String   @unique @db.VarChar(150)
  label     String   @db.VarChar(255)
  value     String   @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_colors")
}

model ProductFinish {
  id           BigInt   @id @default(autoincrement())
  key          String   @unique @db.VarChar(150)
  label        String   @db.VarChar(255)
  color        String?  @db.VarChar(30)
  imageMediaId BigInt?  @map("image_media_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  imageMedia Media? @relation("ProductFinishImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)

  @@index([imageMediaId])
  @@map("product_finishes")
}

model ArticleCategory {
  id              BigInt   @id @default(autoincrement())
  parentId        BigInt?  @map("parent_id")
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  color           String   @default("#0a8dc1") @db.VarChar(30)
  createdByUserId String?  @map("created_by_user_id")
  updatedByUserId String?  @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent        ArticleCategory?      @relation("ArticleCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      ArticleCategory[]     @relation("ArticleCategoryHierarchy")
  createdByUser User?                 @relation("ArticleCategoryCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?                 @relation("ArticleCategoryUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  articleLinks  ArticleCategoryLink[]

  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("article_categories")
}

model Article {
  id                BigInt    @id @default(autoincrement())
  authorId          String    @map("author_id")
  updatedByUserId   String?   @map("updated_by_user_id")
  publishedByUserId String?   @map("published_by_user_id")
  archivedByUserId  String?   @map("archived_by_user_id")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedAt         DateTime? @map("deleted_at")

  title          String        @db.VarChar(255)
  displayTitle   String?       @map("display_title") @db.VarChar(255)
  slug           String        @unique @db.VarChar(255)
  excerpt        String?       @db.Text
  content        String        @db.Text
  descriptionSeo String?       @map("description_seo") @db.VarChar(160)
  tags           String        @default("") @db.Text
  status         ArticleStatus
  publishedAt    DateTime?     @map("published_at")
  coverMediaId   BigInt?       @map("cover_media_id")
  ogTitle        String?       @map("og_title") @db.VarChar(255)
  ogDescription  String?       @map("og_description") @db.Text
  ogImageMediaId BigInt?       @map("og_image_media_id")
  noIndex        Boolean       @default(false) @map("no_index")
  noFollow       Boolean       @default(false) @map("no_follow")
  schemaType     String?       @map("schema_type") @db.VarChar(100)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  author       User   @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  coverMedia   Media? @relation("ArticleCoverMedia", fields: [coverMediaId], references: [id], onDelete: SetNull)
  ogImageMedia Media? @relation("ArticleOgImageMedia", fields: [ogImageMediaId], references: [id], onDelete: SetNull)

  categoryLinks ArticleCategoryLink[]
  authorLinks   ArticleAuthorLink[]
  mediaLinks    ArticleMediaLink[]

  @@index([authorId])
  @@index([coverMediaId])
  @@index([ogImageMediaId])
  @@index([status])
  @@map("articles")
}

model ArticleCategoryLink {
  articleId  BigInt   @map("article_id")
  categoryId BigInt   @map("category_id")
  score      Int
  createdAt  DateTime @default(now()) @map("created_at")

  article  Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([articleId, categoryId])
  @@index([categoryId])
  @@map("article_category_links")
}

model ArticleAuthorLink {
  articleId BigInt   @map("article_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([articleId, userId])
  @@index([userId])
  @@map("article_author_links")
}

model ArticleMediaLink {
  articleId BigInt        @map("article_id")
  mediaId   BigInt        @map("media_id")
  role      MediaLinkRole
  sortOrder Int           @default(0) @map("sort_order")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([articleId, mediaId])
  @@index([mediaId])
  @@map("article_media_links")
}

model MediaFolder {
  id              BigInt   @id @default(autoincrement())
  parentId        BigInt?  @map("parent_id")
  name            String   @db.VarChar(255)
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent   MediaFolder?  @relation("MediaFolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children MediaFolder[] @relation("MediaFolderHierarchy")
  media    Media[]

  @@index([parentId])
  @@index([createdByUserId])
  @@map("media_folders")
}

model Media {
  id               BigInt          @id @default(autoincrement())
  folderId         BigInt?         @map("folder_id")
  kind             MediaKind
  visibility       MediaVisibility @default(PRIVATE)
  storagePath      String          @map("storage_path") @db.VarChar(500)
  originalFilename String?         @map("original_filename") @db.VarChar(255)
  mimeType         String?         @map("mime_type") @db.VarChar(255)
  extension        String?         @db.VarChar(32)
  altText          String?         @map("alt_text") @db.VarChar(500)
  title            String?         @db.VarChar(255)
  widthPx          Int?            @map("width_px")
  heightPx         Int?            @map("height_px")
  durationSeconds  Decimal?        @map("duration_seconds") @db.Decimal(10, 2)
  sizeBytes        BigInt?         @map("size_bytes")
  sha256Hash       String?         @map("sha256_hash") @db.VarChar(128)
  isActive         Boolean         @default(true) @map("is_active")
  uploadedByUserId String?         @map("uploaded_by_user_id")
  updatedByUserId  String?         @map("updated_by_user_id")
  deletedAt        DateTime?       @map("deleted_at")
  deletedByUserId  String?         @map("deleted_by_user_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  folder         MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedByUser User?        @relation("MediaUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  productFamilyMainImageFor  ProductFamily[]      @relation("ProductFamilyMainImageMedia")
  productLinks               ProductMedia[]
  productCategoryImageFor    ProductCategory[]    @relation("ProductCategoryImageMedia")
  productSubcategoryImageFor ProductSubcategory[] @relation("ProductSubcategoryImageMedia")
  staffProfileAvatarFor      StaffProfile[]       @relation("StaffProfileAvatarMedia")
  productFinishImageFor      ProductFinish[]      @relation("ProductFinishImageMedia")
  organizationLogoFor        Organization[]       @relation("OrganizationLogoMedia")
  articleCoverFor            Article[]            @relation("ArticleCoverMedia")
  articleOgImageFor          Article[]            @relation("ArticleOgImageMedia")
  articleMediaLinks          ArticleMediaLink[]

  @@index([folderId])
  @@index([uploadedByUserId])
  @@index([deletedAt])
  @@map("media")
}
