  updatedAt        DateTime @updatedAt @map("updated_at")

  mainImage      Media?                @relation("ProductFamilyMainImageMedia", fields: [mainImageMediaId], references: [id], onDelete: SetNull)
  defaultProduct Product?              @relation("ProductFamilyDefaultProduct", fields: [defaultProductId], references: [id], onDelete: SetNull)
  members        ProductFamilyMember[]

  @@index([mainImageMediaId])
  @@index([defaultProductId])
  @@map("product_families")
}

model ProductFamilyMember {
  familyId  BigInt @map("family_id")
  productId BigInt @unique @map("product_id")
  sortOrder Int    @default(0) @map("sort_order")

  family  ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([familyId, productId])
  @@index([sortOrder])
  @@map("product_family_members")
}

model ProductTypeGroup {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productTypes ProductType[]

  @@index([sortOrder])
  @@map("product_type_groups")
}

model ProductType {
  id                    BigInt     @id @default(autoincrement())
  groupId               BigInt?    @map("group_id")
  name                  String     @db.VarChar(255)
  displayName           String     @map("display_name") @db.VarChar(255)
  slug                  String     @unique @db.VarChar(255)
  hint                  String?    @db.Text
  description           String?    @db.Text
  titleSeo              String?    @map("title_seo") @db.VarChar(60)
  descriptionSeo        String?    @map("description_seo") @db.VarChar(160)
  mediaImageId          BigInt?    @map("media_image_id")
  sortOrder             Int        @default(0) @map("sort_order")
  hasColor              Boolean    @default(false) @map("has_color")
  hasFinish             Boolean    @default(false) @map("has_finish")
  presetTags            String     @default("") @map("preset_tags") @db.Text
  presetStockUnit       StockUnit? @map("preset_stock_unit")
  presetVatRate         Decimal?   @map("preset_vat_rate") @db.Decimal(5, 3)
  presetGuaranteeMonths Int?       @map("preset_guarantee_months")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  group              ProductTypeGroup?              @relation(fields: [groupId], references: [id], onDelete: SetNull)
  mediaImage         Media?                         @relation("ProductTypeMediaImage", fields: [mediaImageId], references: [id], onDelete: SetNull)
  attributeGroups    ProductAttributeGroup[]
  attributes         ProductTypeAttribute[]
  subcategoryPresets ProductTypeSubcategoryPreset[]
  products           Product[]

  @@index([groupId])
  @@index([mediaImageId])
  @@index([sortOrder])
  @@map("product_type_templates")
}

model ProductTypeSubcategoryPreset {
  productTypeId BigInt @map("product_type_id")
  subcategoryId BigInt @map("subcategory_id")

  productType ProductType        @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  subcategory ProductSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  @@id([productTypeId, subcategoryId])
  @@index([subcategoryId])
  @@map("product_type_subcategory_presets")
}

model ProductAttributeGroup {
  id            BigInt   @id @default(autoincrement())
  productTypeId BigInt?  @map("product_type_id")
  name          String   @db.VarChar(255)
  slug          String   @db.VarChar(255)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  productType       ProductType?           @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  attributeDefs     ProductTypeAttribute[]
  productAttributes ProductAttribute[]

  @@unique([productTypeId, slug])
  @@index([productTypeId])
  @@index([sortOrder])
  @@map("product_attribute_groups")
}

model ProductAttributeDefinition {
  id            BigInt                        @id @default(autoincrement())
  key           String                        @unique @db.VarChar(150)
  label         String                        @db.VarChar(255)
  unit          String?                       @db.VarChar(50)
  inputType     ProductTypeAttributeInputType @default(TEXT) @map("input_type")
  selectOptions String[]                      @default([]) @map("select_options")
  createdAt     DateTime                      @default(now()) @map("created_at")
  updatedAt     DateTime                      @updatedAt @map("updated_at")

  templateAttributes ProductTypeAttribute[]
  productAttributes  ProductAttribute[]

  @@index([label])
  @@map("product_attribute_definitions")
}

model ProductTypeAttribute {
  id                    BigInt   @id @default(autoincrement())
  productTypeId         BigInt   @map("product_type_id")
  attributeGroupId      BigInt?  @map("attribute_group_id")
  attributeDefinitionId BigInt   @map("attribute_definition_id")
  label                 String   @default("") @db.VarChar(255)
  isRequired            Boolean  @default(false) @map("is_required")
  isFilterable          Boolean  @default(false) @map("is_filterable")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  productType         ProductType                @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  attributeGroup      ProductAttributeGroup?     @relation(fields: [attributeGroupId], references: [id], onDelete: SetNull)
  attributeDefinition ProductAttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Restrict)

  @@unique([productTypeId, attributeDefinitionId])
  @@index([productTypeId])
  @@index([attributeGroupId])
  @@index([attributeDefinitionId])
  @@index([sortOrder])
  @@map("product_type_attributes")
}

model ProductAttribute {
  id               BigInt                        @id @default(autoincrement())
  productId        BigInt                        @map("product_id")
  attributeDefId   BigInt?                       @map("attribute_def_id")
  attributeGroupId BigInt?                       @map("attribute_group_id")
  name             String                        @db.VarChar(150)
  label            String                        @default("") @db.VarChar(255)
  value            String                        @db.VarChar(255)
  unit             String?                       @db.VarChar(50)
  inputType        ProductTypeAttributeInputType @default(TEXT) @map("input_type")
  isRequired       Boolean                       @default(false) @map("is_required")
  isFilterable     Boolean                       @default(false) @map("is_filterable")
  groupName        String?                       @map("group_name") @db.VarChar(255)
  groupSortOrder   Int                           @default(0) @map("group_sort_order")
  sortOrder        Int                           @default(0) @map("sort_order")

  product        Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeDef   ProductAttributeDefinition? @relation(fields: [attributeDefId], references: [id], onDelete: SetNull)
  attributeGroup ProductAttributeGroup?      @relation(fields: [attributeGroupId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([attributeDefId])
  @@index([attributeGroupId])
  @@index([groupSortOrder])
  @@index([sortOrder])
  @@map("product_attributes")
}

model ProductColor {
  id        BigInt   @id @default(autoincrement())
  key       String   @unique @db.VarChar(150)
  label     String   @db.VarChar(255)
  value     String   @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_colors")
}

model ProductFinish {
  id           BigInt   @id @default(autoincrement())
  key          String   @unique @db.VarChar(150)
  label        String   @db.VarChar(255)
  color        String?  @db.VarChar(30)
  imageMediaId BigInt?  @map("image_media_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  imageMedia Media? @relation("ProductFinishImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)

  @@index([imageMediaId])
  @@map("product_finishes")
}

model ArticleCategory {
  id              BigInt   @id @default(autoincrement())
  parentId        BigInt?  @map("parent_id")
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  color           String   @default("#0a8dc1") @db.VarChar(30)
  createdByUserId String?  @map("created_by_user_id")
  updatedByUserId String?  @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent        ArticleCategory?      @relation("ArticleCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      ArticleCategory[]     @relation("ArticleCategoryHierarchy")
  createdByUser User?                 @relation("ArticleCategoryCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?                 @relation("ArticleCategoryUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  articleLinks  ArticleCategoryLink[]

  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("article_categories")
}

model Article {
  id                BigInt    @id @default(autoincrement())
  authorId          String    @map("author_id")
  updatedByUserId   String?   @map("updated_by_user_id")
  publishedByUserId String?   @map("published_by_user_id")
  archivedByUserId  String?   @map("archived_by_user_id")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedAt         DateTime? @map("deleted_at")

  title          String        @db.VarChar(255)
  displayTitle   String?       @map("display_title") @db.VarChar(255)
  slug           String        @unique @db.VarChar(255)
  excerpt        String?       @db.Text
  content        String        @db.Text
  descriptionSeo String?       @map("description_seo") @db.VarChar(160)
  tags           String        @default("") @db.Text
  status         ArticleStatus
  publishedAt    DateTime?     @map("published_at")
  coverMediaId   BigInt?       @map("cover_media_id")
  ogTitle        String?       @map("og_title") @db.VarChar(255)
  ogDescription  String?       @map("og_description") @db.Text
  ogImageMediaId BigInt?       @map("og_image_media_id")
  noIndex        Boolean       @default(false) @map("no_index")
  noFollow       Boolean       @default(false) @map("no_follow")
  schemaType     String?       @map("schema_type") @db.VarChar(100)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  author       User   @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  coverMedia   Media? @relation("ArticleCoverMedia", fields: [coverMediaId], references: [id], onDelete: SetNull)
  ogImageMedia Media? @relation("ArticleOgImageMedia", fields: [ogImageMediaId], references: [id], onDelete: SetNull)

  categoryLinks ArticleCategoryLink[]
  authorLinks   ArticleAuthorLink[]
  mediaLinks    ArticleMediaLink[]

  @@index([authorId])
  @@index([coverMediaId])
  @@index([ogImageMediaId])
  @@index([status])
  @@map("articles")
}

model ArticleCategoryLink {
  articleId  BigInt   @map("article_id")
  categoryId BigInt   @map("category_id")
  score      Int
  createdAt  DateTime @default(now()) @map("created_at")

  article  Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([articleId, categoryId])
  @@index([categoryId])
  @@map("article_category_links")
}

model ArticleAuthorLink {
  articleId BigInt   @map("article_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([articleId, userId])
  @@index([userId])
  @@map("article_author_links")
}

model ArticleMediaLink {
  articleId BigInt        @map("article_id")
  mediaId   BigInt        @map("media_id")
  role      MediaLinkRole
  sortOrder Int           @default(0) @map("sort_order")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([articleId, mediaId])
  @@index([mediaId])
  @@map("article_media_links")
}

model MediaFolder {
  id              BigInt   @id @default(autoincrement())
  parentId        BigInt?  @map("parent_id")
  name            String   @db.VarChar(255)
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent   MediaFolder?  @relation("MediaFolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children MediaFolder[] @relation("MediaFolderHierarchy")
  media    Media[]

  @@index([parentId])
  @@index([createdByUserId])
  @@map("media_folders")
}

model Media {
  id               BigInt          @id @default(autoincrement())
  folderId         BigInt?         @map("folder_id")
  kind             MediaKind
  visibility       MediaVisibility @default(PRIVATE)
  storagePath      String          @map("storage_path") @db.VarChar(500)
  originalFilename String?         @map("original_filename") @db.VarChar(255)
  mimeType         String?         @map("mime_type") @db.VarChar(255)
  extension        String?         @db.VarChar(32)
  altText          String?         @map("alt_text") @db.VarChar(500)
  title            String?         @db.VarChar(255)
  widthPx          Int?            @map("width_px")
  heightPx         Int?            @map("height_px")
  durationSeconds  Decimal?        @map("duration_seconds") @db.Decimal(10, 2)
  sizeBytes        BigInt?         @map("size_bytes")
  sha256Hash       String?         @map("sha256_hash") @db.VarChar(128)
  isActive         Boolean         @default(true) @map("is_active")
  uploadedByUserId String?         @map("uploaded_by_user_id")
  updatedByUserId  String?         @map("updated_by_user_id")
  deletedAt        DateTime?       @map("deleted_at")
  deletedByUserId  String?         @map("deleted_by_user_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  folder         MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedByUser User?        @relation("MediaUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  productFamilyMainImageFor  ProductFamily[]      @relation("ProductFamilyMainImageMedia")
  productLinks               ProductMedia[]
  productCategoryImageFor    ProductCategory[]    @relation("ProductCategoryImageMedia")
  productSubcategoryImageFor ProductSubcategory[] @relation("ProductSubcategoryImageMedia")
  productTypeMediaImageFor   ProductType[]        @relation("ProductTypeMediaImage")
  staffProfileAvatarFor      StaffProfile[]       @relation("StaffProfileAvatarMedia")
  productFinishImageFor      ProductFinish[]      @relation("ProductFinishImageMedia")
  organizationLogoFor        Organization[]       @relation("OrganizationLogoMedia")
  commerceInvoicePdfs        CommerceInvoice[]    @relation("CommerceInvoicePdfMedia")
  commercePromotionBanners   CommercePromotion[]  @relation("CommercePromotionBannerMedia")
  articleCoverFor            Article[]            @relation("ArticleCoverMedia")
  articleOgImageFor          Article[]            @relation("ArticleOgImageMedia")
  articleMediaLinks          ArticleMediaLink[]

  @@index([folderId])
  @@index([uploadedByUserId])
  @@index([deletedAt])
  @@map("media")
}
