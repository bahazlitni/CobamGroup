model Product {
  id BigInt @id @default(autoincrement())

  brandId       BigInt? @map("brand_id")
  productTypeId BigInt  @map("product_type_id")

  kind        ProductKind      @default(STANDARD)
  lifecycle   ProductLifecycle @default(ACTIVE)
  slug        String           @unique @db.VarChar(255)
  sku         String           @unique @db.VarChar(100)
  name        String           @db.VarChar(255)
  displayName String           @map("display_name") @db.VarChar(255)

  richTextDescription Json? @map("rich_text_description") @db.Json

  titleSeo       String? @map("title_seo") @db.VarChar(60)
  descriptionSeo String? @map("description_seo") @db.VarChar(160)
  tags           String  @default("") @db.Text

  guaranteeMonths Int? @default(0) @map("guarantee_months")

  visibleEcommerce Boolean @default(true) @map("visible_ecommerce")
  visibleVitrine   Boolean @default(true) @map("visible_vitrine")
  isFeatured       Boolean @default(false) @map("is_featured")
  isNew            Boolean @default(false) @map("is_new")

  stockAvailable      Decimal                    @default(0) @map("stock_available") @db.Decimal(12, 3)
  stockAlertThreshold Decimal                    @default(0) @map("stock_alert_threshold") @db.Decimal(12, 3)
  stockUnit           StockUnit                  @default(PIECE) @map("stock_unit")
  stockAvailability   ProductAvailability        @default(IN_STOCK) @map("stock_availability")
  stockVisibility     ProductInventoryVisibility @default(AUTO) @map("stock_visibility")

  basePriceTtcTnd    Decimal?                 @map("base_price_ttc_tnd") @db.Decimal(12, 3)
  currentPriceTtcTnd Decimal?                 @map("current_price_ttc_tnd") @db.Decimal(12, 3)
  vatRate            Decimal                  @default(19.000) @map("vat_rate") @db.Decimal(5, 3)
  priceVisibility    ProductPricingVisibility @default(AUTO) @map("price_visibility")

  createdById     String?  @map("created_by_id") @db.VarChar(191)
  lastUpdatedById String?  @map("last_updated_by_id") @db.VarChar(191)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  familyMembership   ProductFamilyMember?
  defaultForFamilies ProductFamily[]            @relation("ProductFamilyDefaultProduct")
  brand              Organization?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  productType        ProductType                @relation(fields: [productTypeId], references: [id], onDelete: Restrict)
  subcategories      ProductSubcategoryLink[]
  media              ProductMedia[]
  attributes         ProductAttribute[]
  cartItems          ShoppingCartItem[]
  orderItems         CommerceOrderItem[]
  promotionLinks     CommercePromotionProduct[]
  wishlistItems      CommerceWishlistItem[]
  stockReservations  CommerceStockReservation[]

  @@index([brandId])
  @@index([productTypeId])
  @@index([lifecycle])
  @@index([visibleEcommerce])
  @@index([visibleVitrine])
  @@index([isFeatured])
  @@map("products")
}

