{
  "name": "@cobam/cobam-group",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run db:generate --workspace-root",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npm run db:generate --workspace-root",
    "db:validate": "npm run db:validate --workspace-root",
    "db:migrate:dev": "npm run db:migrate:dev --workspace-root",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace-root",
    "rbac:reset": "tsx scripts/reset-rbac-roles.ts",
    "staff:seed": "tsx scripts/seed-staff-users.ts",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cobam/db": "*",
    "@cobam/media-storage": "*"
  }
}
