{
  "name": "@cobam/cobam-group",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm --prefix ../.. run db:generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npm --prefix ../.. run db:generate",
    "db:validate": "npm --prefix ../.. run db:validate",
    "db:migrate:dev": "npm --prefix ../.. run db:migrate:dev",
    "db:migrate:deploy": "npm --prefix ../.. run db:migrate:deploy",
    "rbac:reset": "tsx scripts/reset-rbac-roles.ts",
    "staff:seed": "tsx scripts/seed-staff-users.ts",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cobam/db": "*",
    "@cobam/media-storage": "*",
    "@cobam/shared": "*",
    "framer-motion": "^12.40.0"
  }
}
