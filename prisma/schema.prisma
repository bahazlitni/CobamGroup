generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MediaKind {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaVisibility {
  PRIVATE
  PUBLIC
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaLinkRole {
  COVER
  GALLERY
  THUMBNAIL
  BANNER
  SEO_COVER
  SWATCH
  INLINE
  TECHNICAL_SHEET_IMAGE
  LIFESTYLE
}

enum Portal {
  CUSTOMER
  STAFF
}

enum PowerType {
  ROOT
  ADMIN
  STAFF
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  CLOSED
}

enum ProductKind {
  VARIANT
  PACK
  SINGLE
}

enum ProductLifecycle {
  DRAFT
  ACTIVE
}

enum ProductCommercialMode {
  ON_REQUEST_ONLY
  ON_REQUEST_OR_ONLINE
  ONLINE_ONLY
}

enum ProductStockUnit {
  ITEM
  KILOGRAM
  LITER
  CUBIC_METER
  METER
  SQUARE_METER
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  ATTACH
  DETACH
  PUBLISH
  UNPUBLISH
  RESTORE
  ARCHIVE
  ROLE_GRANT
  ROLE_REVOKE
  BAN
  UNBAN
  PASSWORD_CHANGE
  LOGIN
  LOGOUT
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String     @map("password_hash")
  portal            Portal     @default(STAFF)
  powerType         PowerType  @default(STAFF) @map("power_type")
  status            UserStatus @default(ACTIVE)
  bannedAt          DateTime?  @map("banned_at")
  bannedReason      String?    @map("banned_reason") @db.Text
  closedAt          DateTime?  @map("closed_at")
  lastLoginAt       DateTime?  @map("last_login_at")
  passwordChangedAt DateTime?  @map("password_changed_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  refreshTokens            RefreshToken[]
  uploadedMedia            Media[]             @relation("MediaUploadedByUser")
  articles                 Article[]           @relation("ArticleAuthor")
  articleAuthorLinks       ArticleAuthorLink[]
  createdArticleCategories ArticleCategory[]   @relation("ArticleCategoryCreatedByUser")
  updatedArticleCategories ArticleCategory[]   @relation("ArticleCategoryUpdatedByUser")
  auditLogs                AuditLog[]          @relation("AuditActor")
  profile                  StaffProfile?

  receivedRoleAssignments UserRoleAssignment[] @relation("RoleAssignmentTarget")
  grantedRoleAssignments  UserRoleAssignment[] @relation("RoleAssignmentGrantedBy")
  revokedRoleAssignments  UserRoleAssignment[] @relation("RoleAssignmentRevokedBy")

  @@index([powerType])
  @@index([status])
  @@map("users")
}

model StaffProfile {
  id            BigInt    @id @default(autoincrement())
  userId        String    @unique @map("user_id")
  firstName     String?   @map("first_name") @db.VarChar(100)
  lastName      String?   @map("last_name") @db.VarChar(100)
  jobTitle      String?   @map("job_title") @db.VarChar(150)
  phone         String?   @db.VarChar(50)
  bio           String?
  birthDate     DateTime? @map("birth_date")
  avatarMediaId BigInt?   @map("avatar_media_id")

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarMedia Media? @relation("StaffProfileAvatarMedia", fields: [avatarMediaId], references: [id], onDelete: SetNull)

  @@index([avatarMediaId])
  @@map("profiles")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  key         String   @unique @db.VarChar(150) // e.g. "products.update.own"
  label       String   @db.VarChar(255)
  resource    String   @db.VarChar(100) // e.g. "products"
  action      String   @db.VarChar(100) // e.g. "update"
  scope       String?  @db.VarChar(50) // e.g. "own", "any", "below_role"
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roleLinks RolePermission[]

  @@index([resource, action])
  @@map("permissions")
}

model Role {
  id            BigInt   @id @default(autoincrement())
  key           String   @unique @db.VarChar(100)
  name          String   @db.VarChar(150)
  color         String   @db.VarChar(30)
  priorityIndex Int      @default(100) @map("priority_index")
  description   String?  @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  permissionLinks RolePermission[]
  userAssignments UserRoleAssignment[]

  @@index([priorityIndex])
  @@index([isActive])
  @@map("roles")
}

model RolePermission {
  roleId       BigInt  @map("role_id")
  permissionId BigInt  @map("permission_id")
  allowed      Boolean @default(true)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id              BigInt    @id @default(autoincrement())
  userId          String    @map("user_id")
  roleId          BigInt    @map("role_id")
  grantedByUserId String?   @map("granted_by_user_id")
  revokedByUserId String?   @map("revoked_by_user_id")
  grantedAt       DateTime  @default(now()) @map("granted_at")
  revokedAt       DateTime? @map("revoked_at")
  reason          String?   @db.Text

  user          User  @relation("RoleAssignmentTarget", fields: [userId], references: [id], onDelete: Cascade)
  role          Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedByUser User? @relation("RoleAssignmentGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  revokedByUser User? @relation("RoleAssignmentRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt])
  @@index([roleId, revokedAt])
  @@map("user_role_assignments")
}

model RefreshToken {
  id                 String    @id @default(cuid())
  tokenHash          String    @map("token_hash")
  userId             String    @map("user_id")
  expiresAt          DateTime  @map("expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  revokedAt          DateTime? @map("revoked_at")
  lastUsedAt         DateTime? @map("last_used_at")
  createdByIpAddress String?   @map("created_by_ip_address") @db.VarChar(100)
  createdByUserAgent String?   @map("created_by_user_agent") @db.Text
  replacedByTokenId  String?   @map("replaced_by_token_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ProductCategory {
  id             BigInt   @id @default(autoincrement())
  name           String   @db.VarChar(255)
  subtitle       String?  @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)
  themeColor     String?  @map("theme_color") @db.VarChar(255)
  description    String?  @db.Text
  descriptionSeo String?  @map("description_seo") @db.Text
  imageMediaId   BigInt?  @map("image_media_id")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  imageMedia    Media?               @relation("ProductCategoryImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)
  subcategories ProductSubcategory[]

  @@index([imageMediaId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("product_types")
}

model ProductSubcategory {
  id             BigInt   @id @default(autoincrement())
  categoryId     BigInt   @map("category_id")
  name           String   @db.VarChar(255)
  subtitle       String?  @db.VarChar(255)
  slug           String   @db.VarChar(255)
  description    String?  @db.Text
  descriptionSeo String?  @map("description_seo") @db.Text
  imageMediaId   BigInt?  @map("image_media_id")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category     ProductCategory          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  imageMedia   Media?                   @relation("ProductSubcategoryImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)
  productLinks ProductSubcategoryLink[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([imageMediaId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("product_subcategories")
}

model Product {
  id              BigInt                 @id @default(autoincrement())
  sku             String                 @unique @db.VarChar(255)
  slug            String                 @unique @db.VarChar(255)
  kind            ProductKind
  name            String                 @db.VarChar(255)
  description     String?                @db.Text
  descriptionSeo  String?                @map("description_seo") @db.Text
  brand           String?                @map("brand")
  basePriceAmount Decimal?               @map("base_price_amount") @db.Decimal(12, 3)
  vatRate         Float?                 @map("vat_rate")
  stock           Decimal?               @db.Decimal(14, 3)
  stockUnit       ProductStockUnit?      @map("stock_unit")
  visibility      Boolean?
  priceVisibility Boolean?               @map("price_visibility")
  stockVisibility Boolean?               @map("stock_visibility")
  lifecycle       ProductLifecycle?
  commercialMode  ProductCommercialMode? @map("commercial_mode")
  tags            String                 @default("") @db.Text
  datasheetMediaId BigInt?               @map("datasheet_media_id")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  familyMembership     ProductFamilyMember?
  defaultForFamilies   ProductFamily[]          @relation("ProductFamilyDefaultProduct")
  subcategoryLinks     ProductSubcategoryLink[]
  datasheetMedia       Media?                   @relation("ProductDatasheetMedia", fields: [datasheetMediaId], references: [id], onDelete: SetNull)
  mediaLinks           ProductMediaLink[]
  attributes           ProductAttribute[]
  packLinesAsPack      ProductPackLine[]        @relation("ProductPackLines")
  packLinesAsComponent ProductPackLine[]        @relation("ProductPackComponents")

  @@index([kind])
  @@index([brand])
  @@index([lifecycle])
  @@index([visibility])
  @@index([priceVisibility])
  @@index([stockVisibility])
  @@index([commercialMode])
  @@index([datasheetMediaId])
  @@map("products")
}



model ProductSubcategoryLink {
  productId     BigInt @map("product_id")
  subcategoryId BigInt @map("subcategory_id")

  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  subcategory ProductSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  @@id([productId, subcategoryId])
  @@index([subcategoryId])
  @@map("product_subcategory_links")
}

model ProductMediaLink {
  productId BigInt @map("product_id")
  mediaId   BigInt @map("media_id")
  sortOrder Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([productId, mediaId])
  @@index([mediaId])
  @@index([sortOrder])
  @@map("product_media_links")
}

model ProductFamily {
  id               BigInt   @id @default(autoincrement())
  slug             String   @unique @db.VarChar(255)
  name             String   @db.VarChar(255)
  subtitle         String?  @db.VarChar(255)
  description      String?  @db.Text
  descriptionSeo   String?  @map("description_seo") @db.Text
  mainImageMediaId BigInt?  @map("main_image_media_id")
  defaultProductId BigInt?  @map("default_product_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  mainImage      Media?                @relation("ProductFamilyMainImageMedia", fields: [mainImageMediaId], references: [id], onDelete: SetNull)
  defaultProduct Product?              @relation("ProductFamilyDefaultProduct", fields: [defaultProductId], references: [id], onDelete: SetNull)
  members        ProductFamilyMember[]

  @@index([mainImageMediaId])
  @@index([defaultProductId])
  @@map("product_families")
}

model ProductFamilyMember {
  familyId  BigInt @map("family_id")
  productId BigInt @unique @map("product_id")
  sortOrder Int    @default(0) @map("sort_order")

  family  ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([familyId, productId])
  @@index([sortOrder])
  @@map("product_family_members")
}

model ProductAttribute {
  productId BigInt               @map("product_id")
  kind      String
  value     String               @db.Text
  sortOrder Int                  @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, kind])
  @@index([sortOrder])
  @@map("product_attributes")
}

model ProductPackLine {
  packProductId BigInt @map("pack_product_id")
  productId     BigInt @map("product_id")
  quantity      Int    @default(1)
  sortOrder     Int    @default(0) @map("sort_order")

  packProduct Product @relation("ProductPackLines", fields: [packProductId], references: [id], onDelete: Cascade)
  product     Product @relation("ProductPackComponents", fields: [productId], references: [id], onDelete: Restrict)

  @@id([packProductId, productId])
  @@index([productId])
  @@index([sortOrder])
  @@map("product_pack_lines")
}

model ArticleCategory {
  id              BigInt   @id @default(autoincrement())
  parentId        BigInt?  @map("parent_id")
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  color           String   @default("#0a8dc1") @db.VarChar(30)
  createdByUserId String?  @map("created_by_user_id")
  updatedByUserId String?  @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent        ArticleCategory?      @relation("ArticleCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      ArticleCategory[]     @relation("ArticleCategoryHierarchy")
  createdByUser User?                 @relation("ArticleCategoryCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?                 @relation("ArticleCategoryUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  articleLinks  ArticleCategoryLink[]

  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("article_categories")
}

model Article {
  id                BigInt    @id @default(autoincrement())
  authorId          String    @map("author_id")
  updatedByUserId   String?   @map("updated_by_user_id")
  publishedByUserId String?   @map("published_by_user_id")
  archivedByUserId  String?   @map("archived_by_user_id")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedAt         DateTime? @map("deleted_at")

  title          String        @db.VarChar(255)
  displayTitle   String?       @map("display_title") @db.VarChar(255)
  slug           String        @unique @db.VarChar(255)
  excerpt        String?       @db.Text
  content        String        @db.Text
  descriptionSeo String?       @map("description_seo") @db.Text
  tags           String        @default("") @db.Text
  status         ArticleStatus
  publishedAt    DateTime?     @map("published_at")
  coverMediaId   BigInt?       @map("cover_media_id")
  ogTitle        String?       @map("og_title") @db.VarChar(255)
  ogDescription  String?       @map("og_description") @db.Text
  ogImageMediaId BigInt?       @map("og_image_media_id")
  noIndex        Boolean       @default(false) @map("no_index")
  noFollow       Boolean       @default(false) @map("no_follow")
  schemaType     String?       @map("schema_type") @db.VarChar(100)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  author       User   @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  coverMedia   Media? @relation("ArticleCoverMedia", fields: [coverMediaId], references: [id], onDelete: SetNull)
  ogImageMedia Media? @relation("ArticleOgImageMedia", fields: [ogImageMediaId], references: [id], onDelete: SetNull)

  categoryLinks ArticleCategoryLink[]
  authorLinks   ArticleAuthorLink[]
  mediaLinks    ArticleMediaLink[]

  @@index([authorId])
  @@index([coverMediaId])
  @@index([ogImageMediaId])
  @@index([status])
  @@map("articles")
}

model ArticleCategoryLink {
  articleId  BigInt   @map("article_id")
  categoryId BigInt   @map("category_id")
  score      Int
  createdAt  DateTime @default(now()) @map("created_at")

  article  Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([articleId, categoryId])
  @@index([categoryId])
  @@map("article_category_links")
}

model ArticleAuthorLink {
  articleId BigInt   @map("article_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([articleId, userId])
  @@index([userId])
  @@map("article_author_links")
}

model ArticleMediaLink {
  articleId BigInt        @map("article_id")
  mediaId   BigInt        @map("media_id")
  role      MediaLinkRole
  sortOrder Int           @default(0) @map("sort_order")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([articleId, mediaId])
  @@index([mediaId])
  @@map("article_media_links")
}

model MediaFolder {
  id              BigInt   @id @default(autoincrement())
  parentId        BigInt?  @map("parent_id")
  name            String   @db.VarChar(255)
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent   MediaFolder?  @relation("MediaFolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children MediaFolder[] @relation("MediaFolderHierarchy")
  media    Media[]

  @@index([parentId])
  @@index([createdByUserId])
  @@map("media_folders")
}

model Media {
  id               BigInt          @id @default(autoincrement())
  folderId         BigInt?         @map("folder_id")
  kind             MediaKind
  visibility       MediaVisibility @default(PRIVATE)
  storagePath      String          @map("storage_path") @db.VarChar(500)
  originalFilename String?         @map("original_filename") @db.VarChar(255)
  mimeType         String?         @map("mime_type") @db.VarChar(255)
  extension        String?         @db.VarChar(32)
  altText          String?         @map("alt_text") @db.VarChar(500)
  title            String?         @db.VarChar(255)
  description      String?         @db.Text
  widthPx          Int?            @map("width_px")
  heightPx         Int?            @map("height_px")
  durationSeconds  Decimal?        @map("duration_seconds") @db.Decimal(10, 2)
  sizeBytes        BigInt?         @map("size_bytes")
  sha256Hash       String?         @map("sha256_hash") @db.VarChar(128)
  isActive         Boolean         @default(true) @map("is_active")
  uploadedByUserId String?         @map("uploaded_by_user_id")
  updatedByUserId  String?         @map("updated_by_user_id")
  deletedAt        DateTime?       @map("deleted_at")
  deletedByUserId  String?         @map("deleted_by_user_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  folder         MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
    uploadedByUser User?        @relation("MediaUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

    productFamilyMainImageFor  ProductFamily[]      @relation("ProductFamilyMainImageMedia")
    productDatasheetFor        Product[]            @relation("ProductDatasheetMedia")
    productLinks               ProductMediaLink[]
    productCategoryImageFor    ProductCategory[]    @relation("ProductCategoryImageMedia")
  productSubcategoryImageFor ProductSubcategory[] @relation("ProductSubcategoryImageMedia")
  staffProfileAvatarFor      StaffProfile[]       @relation("StaffProfileAvatarMedia")
  articleCoverFor            Article[]            @relation("ArticleCoverMedia")
  articleOgImageFor          Article[]            @relation("ArticleOgImageMedia")
  articleMediaLinks          ArticleMediaLink[]

  @@index([folderId])
  @@index([uploadedByUserId])
  @@index([deletedAt])
  @@map("media")
}

model AuditLog {
  id                 BigInt          @id @default(autoincrement())
  actorUserId        String?         @map("actor_user_id")
  actionType         AuditActionType @map("action_type")
  entityType         String          @map("entity_type") @db.VarChar(100)
  entityId           String          @map("entity_id") @db.VarChar(100)
  targetLabel        String?         @map("target_label") @db.VarChar(255)
  summary            String?         @db.Text
  reason             String?         @db.Text
  requestId          String?         @map("request_id") @db.VarChar(255)
  ipAddress          String?         @map("ip_address") @db.VarChar(100)
  userAgent          String?         @map("user_agent") @db.Text
  beforeSnapshotJson Json?           @map("before_snapshot_json")
  afterSnapshotJson  Json?           @map("after_snapshot_json")
  createdAt          DateTime        @default(now()) @map("created_at")

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  fieldChanges    AuditLogFieldChange[]
  relationChanges AuditLogRelationChange[]

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([actionType])
  @@index([createdAt])
  @@map("audit_logs")
}

model AuditLogFieldChange {
  id           BigInt  @id @default(autoincrement())
  auditLogId   BigInt  @map("audit_log_id")
  fieldName    String  @map("field_name") @db.VarChar(255)
  oldValueText String? @map("old_value_text") @db.Text
  newValueText String? @map("new_value_text") @db.Text

  auditLog AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)

  @@index([auditLogId])
  @@map("audit_log_field_changes")
}

model AuditLogRelationChange {
  id              BigInt          @id @default(autoincrement())
  auditLogId      BigInt          @map("audit_log_id")
  relationName    String          @map("relation_name") @db.VarChar(255)
  actionType      AuditActionType @map("action_type")
  leftEntityType  String          @map("left_entity_type") @db.VarChar(100)
  leftEntityId    String          @map("left_entity_id") @db.VarChar(100)
  rightEntityType String          @map("right_entity_type") @db.VarChar(100)
  rightEntityId   String          @map("right_entity_id") @db.VarChar(100)
  detailsJson     Json?           @map("details_json")

  auditLog AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)

  @@index([auditLogId])
  @@index([leftEntityType, leftEntityId])
  @@index([rightEntityType, rightEntityId])
  @@map("audit_log_relation_changes")
}

