      FROM "product_media" "pm"
      JOIN "media" "m"
        ON "m"."id" = "pm"."media_id"
        AND "m"."kind" = 'IMAGE'
        AND "m"."is_active" = true
        AND "m"."deleted_at" IS NULL
      WHERE "pm"."product_id" = "p"."id"
        AND "pm"."role" = 'GALLERY'
      ORDER BY "pm"."sort_order" ASC, "pm"."media_id" ASC
