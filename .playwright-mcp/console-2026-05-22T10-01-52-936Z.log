          )
          OR (
            "p"."brand_id" IS NOT NULL
            AND EXISTS (
              SELECT 1
              FROM "commerce_promotion_brands" "promotion_brand"
              WHERE "promotion_brand"."promotion_id" = "promotion"."id"
