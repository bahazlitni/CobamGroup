        AND "s"."visible_ecommerce" = true
      JOIN "product_types" "c"
        ON "c"."id" = "s"."category_id"
        AND "c"."is_active" = true
      WHERE "l"."product_id" = "p"."id"
      ORDER BY "c"."sort_order" ASC, "s"."sort_order" ASC, "s"."name" ASC
      LIMIT 1
    ) "trail" ON true
    LEFT JOIN LATERAL (
