    SELECT
      "c"."id",
      "c"."name",
      "c"."slug",
      "c"."subtitle",
      "c"."description",
      "c"."image_media_id",
      COUNT(DISTINCT "p"."id")::bigint AS "product_count"
    FROM "product_types" "c"
    JOIN "product_subcategories" "s"
      ON "s"."category_id" = "c"."id"
      AND "s"."is_active" = true
      AND "s"."visible_ecommerce" = true
