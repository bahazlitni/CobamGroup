    GROUP BY
      "c"."id",
      "c"."name",
      "c"."slug",
      "c"."subtitle",
      "c"."description",
      "c"."image_media_id",
      "c"."sort_order"
    ORDER BY "c"."sort_order" ASC, "c"."name" ASC
    LIMIT 8
