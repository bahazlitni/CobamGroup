            WHERE "promotion_category"."promotion_id" = "promotion"."id"
              AND "promotion_category"."category_id" = "promotion_subcategory"."category_id"
          )
        )
    )
  
    ORDER BY 
      ("image"."media_id" IS NOT NULL) DESC,
